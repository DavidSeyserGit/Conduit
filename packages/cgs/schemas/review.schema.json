{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://conduit.dev/cgs/0.1/review.schema.json", "title": "CGS 0.1 Review Artifacts", "type": "object",
  "required": ["cgsVersion", "kind", "id", "createdAt", "runId", "goalId", "reviewerId"],
  "properties": { "cgsVersion": { "const": "0.1.0" }, "kind": { "enum": ["review-request", "review-result"] }, "id": { "type": "string", "minLength": 1 }, "createdAt": { "type": "string", "format": "date-time" }, "runId": { "type": "string", "minLength": 1 }, "goalId": { "type": "string", "minLength": 1 }, "reviewerId": { "type": "string", "minLength": 1 }, "confidence": { "type": "number", "minimum": 0, "maximum": 1 } },
  "additionalProperties": true
}
