{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://conduit.dev/cgs/0.1/question.schema.json", "title": "CGS 0.1 Question and Answer Batches",
  "oneOf": [
    { "type": "object", "required": ["cgsVersion", "kind", "id", "createdAt", "goalId", "questions", "sequence", "reason"], "properties": { "cgsVersion": { "const": "0.1.0" }, "kind": { "const": "question-batch" }, "id": { "type": "string", "minLength": 1 }, "createdAt": { "type": "string", "format": "date-time" }, "goalId": { "type": "string", "minLength": 1 }, "questions": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["id", "goalId", "prompt", "required", "type"], "properties": { "id": { "type": "string", "minLength": 1 }, "goalId": { "type": "string", "minLength": 1 }, "prompt": { "type": "string", "minLength": 1 }, "required": { "type": "boolean" }, "type": { "enum": ["single_select", "multi_select", "confirmation", "free_text", "repository_reference", "constraint_editor", "success_criterion_editor"] } }, "additionalProperties": true } }, "sequence": { "type": "integer", "minimum": 0 }, "reason": { "enum": ["goal_clarification", "runtime_decision", "review_blocker"] } }, "additionalProperties": true },
    { "type": "object", "required": ["cgsVersion", "kind", "id", "createdAt", "goalId", "questionBatchId", "answers"], "properties": { "cgsVersion": { "const": "0.1.0" }, "kind": { "const": "answer-batch" }, "id": { "type": "string", "minLength": 1 }, "createdAt": { "type": "string", "format": "date-time" }, "goalId": { "type": "string", "minLength": 1 }, "questionBatchId": { "type": "string", "minLength": 1 }, "answers": { "type": "array", "items": { "type": "object", "required": ["questionId", "value", "answeredAt", "answeredBy"], "properties": { "questionId": { "type": "string", "minLength": 1 }, "answeredAt": { "type": "string", "format": "date-time" }, "answeredBy": { "const": "user" } }, "additionalProperties": true } } }, "additionalProperties": true }
  ]
}
