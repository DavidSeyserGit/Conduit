{
  "name": "@conduit/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --dir ../.. --filter @conduit/shared build && pnpm --dir ../.. --filter @conduit/tools build && pnpm --dir ../.. --filter @conduit/model-providers build && pnpm --dir ../.. --filter @conduit/agent-runtime build",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit && tsc -p tsconfig.backend.json",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@conduit/agent-runtime": "workspace:*",
    "@conduit/model-providers": "workspace:*",
    "@conduit/shared": "workspace:*",
    "@conduit/tools": "workspace:*",
    "@mariozechner/pi-coding-agent": "^0.73.1",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.1.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
