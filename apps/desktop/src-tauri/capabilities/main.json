{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Minimum native access required by the Conduit main window.",
  "windows": ["main"],
  "permissions": [
    "dialog:allow-open",
    "opener:allow-open-url",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:allow-restart",
    "allow-tool-execute",
    "allow-github-client-id",
    "allow-github-get-token",
    "allow-github-store-token",
    "allow-github-device-start",
    "allow-github-device-poll",
    "allow-openrouter-get-key",
    "allow-openrouter-store-key",
    "allow-git-clone-repo",
    "allow-git-worktree-create",
    "allow-git-worktree-remove",
    "allow-git-handoff-status",
    "allow-git-commit-changes",
    "allow-git-push-branch",
    "allow-local-harness-models",
    "allow-local-harness-health",
    "allow-local-harness-response",
    "allow-local-harness-coding-iteration",
    "allow-local-harness-cancel",
    "core:app:allow-version"
  ]
}
